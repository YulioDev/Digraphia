<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:Digrafos.Views"
             x:Class="Digrafos.Views.DrawingAreaView">
  <Grid RowDefinitions="22, *">

    <Border Grid.Row="0" Background="#3C3C3C"
            BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
      <TextBlock Text="Digrafo" Classes="UnityLabel"
                 VerticalAlignment="Center" Margin="8,0,0,0"/>
    </Border>

    <Border Grid.Row="1" Background="#1E1E1E" ClipToBounds="True">
      <Grid>
        <v:GridBackgroundControl x:Name="gridBackground" IsHitTestVisible="False"/>
        <Canvas x:Name="canvasDrawingArea" Background="Transparent"
                Width="2000" Height="2000">
          <Canvas.RenderTransform>
            <TranslateTransform X="0" Y="0"/>
          </Canvas.RenderTransform>
        </Canvas>
      </Grid>
    </Border>

  </Grid>
</UserControl>