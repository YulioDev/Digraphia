<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Digraphia.Views"
             xmlns:node="clr-namespace:Digraphia"
             x:Class="Digraphia.Views.NodeView"
             x:DataType="node:Node"
             Width="40" Height="40">
    <UserControl.Resources>
        <local:StateToFillBrushConverter x:Key="StateToFillBrush"/>
        <local:StateToStrokeBrushConverter x:Key="StateToStrokeBrush"/>
    </UserControl.Resources>
    <Grid>
        <Ellipse Width="40" Height="40" StrokeThickness="2"
                 Fill="{Binding State, Converter={StaticResource StateToFillBrush}}"
                 Stroke="{Binding State, Converter={StaticResource StateToStrokeBrush}}"/>
        <TextBlock Text="{Binding Id}" Foreground="White" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</UserControl>