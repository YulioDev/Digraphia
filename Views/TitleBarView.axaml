<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Digrafos.Views.TitleBarView">
  <Grid Background="#2D2D30" ColumnDefinitions="Auto, *, Auto">

    <TextBlock Grid.Column="0"
               Text="Editor de Digrafos"
               Classes="UnityHeader"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>

    <Panel Grid.Column="1" x:Name="pnlTitleBarDragArea" Background="Transparent"/>

    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" Margin="0,0,5,0">
      <Button x:Name="btnMinimize" Content="─" Width="40" Height="40"
              VerticalAlignment="Stretch" VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              Classes="UnityButton"/>
      <Button x:Name="btnMaximize" Content="□" Width="40" Height="40"
              VerticalAlignment="Stretch" VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              Classes="UnityButton"/>
      <Button x:Name="btnClose" Content="✕" Width="40" Height="40"
              VerticalAlignment="Stretch" VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              Classes="UnityButtonDanger"/>
    </StackPanel>

  </Grid>
</UserControl>