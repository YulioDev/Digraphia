<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Design.PreviewWith>
    <Border Padding="20" Background="#282828" Width="300">
      <StackPanel Spacing="15">
        <Button Classes="UnityButton" Content="Botón Normal" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
        <Button Classes="UnityButtonPrimary" Content="Botón Primario" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
        <Border Classes="UnityContentBox">
          <StackPanel Spacing="8">
            <TextBlock Text="Caja de Contenido" Classes="UnityHeader"/>
            <TextBlock Text="Descripción de ejemplo." Classes="UnitySubText"/>
            <TextBox Classes="UnityTextBox" Watermark="Escribe aquí..."/>
            <ComboBox Classes="UnityComboBox" Width="200">
              <ComboBoxItem Content="Opción 1"/>
              <ComboBoxItem Content="Opción 2"/>
            </ComboBox>
            <CheckBox Classes="UnityCheckBox" Content="Opción activa"/>
            <Slider Classes="UnitySlider" Minimum="0" Maximum="100" Value="40"/>
          </StackPanel>
        </Border>
        <Border Classes="UnityContentBoxDark">
          <TextBlock Text="Caja oscura alternativa" Classes="UnitySubText"/>
        </Border>
        <Border Classes="UnityDivider"/>
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <!-- ===== TIPOGRAFÍA ===== -->
  <Style Selector="TextBlock.UnityHeader">
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="#E0E0E0"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style Selector="TextBlock.UnitySubText">
    <Setter Property="Foreground" Value="#9A9A9A"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style Selector="TextBlock.UnityLabel">
    <Setter Property="Foreground" Value="#BBBBBB"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <!-- ===== BOTÓN ESTÁNDAR ===== -->
  <Style Selector="Button.UnityButton">
    <Setter Property="Background" Value="#585858"/>
    <Setter Property="Foreground" Value="#EEEEEE"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.UnityButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#686868"/>
  </Style>
  <Style Selector="Button.UnityButton:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#3C3C3C"/>
  </Style>
  <Style Selector="Button.UnityButton:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="#404040"/>
    <Setter Property="TextElement.Foreground" Value="#666666"/>
  </Style>

  <!-- ===== BOTÓN PRIMARIO (azul Unity) ===== -->
  <Style Selector="Button.UnityButtonPrimary">
    <Setter Property="Background" Value="#2D5A8E"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#1A3A5C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.UnityButtonPrimary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3A6FA8"/>
  </Style>
  <Style Selector="Button.UnityButtonPrimary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#1E3F63"/>
  </Style>

  <!-- ===== BOTÓN PELIGRO (rojo) ===== -->
  <Style Selector="Button.UnityButtonDanger">
    <Setter Property="Background" Value="#7A2020"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#4A1010"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.UnityButtonDanger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#922828"/>
  </Style>
  <Style Selector="Button.UnityButtonDanger:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#5A1515"/>
  </Style>

  <!-- ===== CAJAS DE CONTENIDO ===== -->
  <Style Selector="Border.UnityContentBox">
    <Setter Property="Background" Value="#3C3C3C"/>
    <Setter Property="BorderBrush" Value="#1F1F1F"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10"/>
  </Style>

  <Style Selector="Border.UnityContentBoxDark">
    <Setter Property="Background" Value="#252525"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10"/>
  </Style>

  <!-- ===== DIVISOR ===== -->
  <Style Selector="Border.UnityDivider">
    <Setter Property="Background" Value="#3A3A3A"/>
    <Setter Property="Height" Value="1"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
  </Style>

  <!-- ===== TEXTBOX ===== -->
  <Style Selector="TextBox.UnityTextBox">
    <Setter Property="Background" Value="#1E1E1E"/>
    <Setter Property="Foreground" Value="#E0E0E0"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="CaretBrush" Value="#E0E0E0"/>
    <Setter Property="SelectionBrush" Value="#2D5A8E"/>
  </Style>
  <Style Selector="TextBox.UnityTextBox:focus">
    <Setter Property="BorderBrush" Value="#4D78A8"/>
  </Style>
  <Style Selector="TextBox.UnityTextBox /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="#666666"/>
  </Style>

  <!-- ===== COMBOBOX ===== -->
  <Style Selector="ComboBox.UnityComboBox">
    <Setter Property="Background" Value="#3C3C3C"/>
    <Setter Property="Foreground" Value="#E0E0E0"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="ComboBox.UnityComboBox:pointerover">
    <Setter Property="BorderBrush" Value="#4D78A8"/>
  </Style>
  <Style Selector="ComboBoxItem.UnityComboBox">
    <Setter Property="Background" Value="#3C3C3C"/>
    <Setter Property="Foreground" Value="#E0E0E0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Padding" Value="6,3"/>
  </Style>

  <!-- ===== CHECKBOX ===== -->
  <Style Selector="CheckBox.UnityCheckBox">
    <Setter Property="Foreground" Value="#C8C8C8"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="CheckBox.UnityCheckBox /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="#1E1E1E"/>
    <Setter Property="BorderBrush" Value="#555555"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="2"/>
  </Style>
  <Style Selector="CheckBox.UnityCheckBox:checked /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="#2D5A8E"/>
    <Setter Property="BorderBrush" Value="#1A3A5C"/>
  </Style>

  <!-- ===== SLIDER ===== -->
<Style Selector="Slider.UnitySlider /template/ Track Thumb">
  <Setter Property="Background" Value="#4D78A8"/>
  <Setter Property="BorderBrush" Value="#1A3A5C"/>
</Style>
<Style Selector="Slider.UnitySlider /template/ Border">
  <Setter Property="Background" Value="#1E1E1E"/>
  <Setter Property="BorderBrush" Value="#1A1A1A"/>
</Style>    

  <!-- ===== SCROLLBAR ===== -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="#2A2A2A"/>
    <Setter Property="Foreground" Value="#555555"/>
    <Setter Property="Width" Value="8"/>
  </Style>

</Styles>